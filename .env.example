# Copy to .env and fill in values before running

# Database (used by docker-compose; override for prod)
POSTGRES_USER=coupletravel
POSTGRES_PASSWORD=coupletravel
POSTGRES_DB=coupletravel

# Blob storage provider: "local" | "r2" | "azure"
BLOB_PROVIDER=local

# Cloudflare R2 (when BLOB_PROVIDER=r2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=couple-travel
R2_PUBLIC_URL=

# Azure Blob (when BLOB_PROVIDER=azure)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=couple-travel

# Cookie auth — use a long random string in prod
COOKIE_SECRET=change-me-in-production-use-a-long-random-string

# Nominatim User-Agent (required by OSM policy; put your email or app name)
NOMINATIM_USER_AGENT=couple-travel-app/1.0 (caophat113@gmail.com)
